# =====================================================================
# EcoStride — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =====================================================================

# ── MongoDB Atlas Connection String ──────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# Get this from: Atlas Dashboard → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ecostride?retryWrites=true&w=majority

# ── JWT Secret ───────────────────────────────────────────────────────
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string

# ── CORS Allowed Origins ─────────────────────────────────────────────
# For local dev: http://localhost:3000
# For production: your Render URL, e.g. https://ecostride.onrender.com
# Multiple origins: comma-separated (no spaces)
ALLOWED_ORIGIN=http://localhost:3000

# ── Server Port ──────────────────────────────────────────────────────
# Render sets this automatically. Only needed locally.
PORT=3000
